<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JARVIS | HAZARD PROTOCOL v7.0</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        :root { 
            --gold: #ffcc00; 
            --orange: #ff6600; 
            --red: #ff0000; 
            --bg: #0a0500; 
        }
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; background: var(--bg); color: var(--gold); font-family: 'Orbitron', sans-serif; overflow: hidden; }

        /* Hexagonal Grid Background */
        #hex-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            opacity: 0.2; z-index: -2;
        }

        #starfield { position: fixed; top: 0; left: 0; z-index: -1; }
        .container { position: relative; height: 100vh; width: 100%; display: flex; justify-content: center; align-items: center; flex-direction: column; }

        /* --- STAGE 1: THE ADVANCED HUD --- */
        .hud-orb { position: relative; width: 350px; height: 350px; display: flex; justify-content: center; align-items: center; cursor: pointer; }
        
        .ring { position: absolute; border-radius: 50%; border: 2px solid transparent; animation: spin 3s linear infinite; }
        .r1 { width: 340px; height: 340px; border-top: 3px solid var(--red); border-bottom: 3px solid var(--red); opacity: 0.6; }
        .r2 { width: 290px; height: 290px; border-left: 2px dashed var(--orange); animation-direction: reverse; animation-duration: 5s; }
        .r3 { width: 220px; height: 220px; border: 5px double var(--gold); box-shadow: inset 0 0 20px var(--orange); }
        
        /* Core Arc Reactor style */
        .core { 
            width: 100px; height: 100px; 
            background: radial-gradient(circle, var(--gold) 10%, var(--orange) 60%, transparent 100%); 
            border-radius: 50%; box-shadow: 0 0 60px var(--orange); 
            animation: pulse 1s infinite alternate;
            display: flex; justify-content: center; align-items: center;
            font-size: 10px; font-weight: bold; color: #000;
        }

        /* Decorative Data Brackets */
        .data-bracket { position: absolute; width: 40px; height: 40px; border: 2px solid var(--gold); }
        .tl { top: -20px; left: -20px; border-right: 0; border-bottom: 0; }
        .br { bottom: -20px; right: -20px; border-left: 0; border-top: 0; }

        /* --- STAGE 2: PROTOCOL PAGE --- */
        #protocol-screen { 
            display: none; text-align: center; border: 1px solid var(--orange); 
            background: rgba(40, 15, 0, 0.9); padding: 50px; 
            box-shadow: 0 0 50px rgba(255, 102, 0, 0.3); border-radius: 10px;
        }
        .btn-activate { 
            background: var(--orange); border: none; color: #000; 
            padding: 15px 40px; font-size: 1.2rem; cursor: pointer; 
            font-weight: bold; letter-spacing: 2px; transition: 0.3s; 
        }
        .btn-activate:hover { background: var(--gold); transform: scale(1.05); box-shadow: 0 0 30px var(--gold); }

        /* --- STAGE 3: SCANNER --- */
        #scanner-screen { 
            display: none; position: relative; width: 350px; height: 450px; 
            border: 3px solid var(--orange); border-radius: 20px; overflow: hidden; 
            box-shadow: 0 0 40px var(--red); 
        }
        #video-feed { width: 100%; height: 100%; object-fit: cover; filter: sepia(1) saturate(2) hue-rotate(-30deg); }
        
        .scan-ring {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 250px; height: 250px; border: 2px solid var(--gold); border-radius: 50%;
        }
        .scan-line {
            position: absolute; width: 100%; height: 5px; 
            background: linear-gradient(transparent, var(--red), transparent);
            top: 0; animation: scanMove 2.5s infinite linear;
        }

        #pass-area { 
            position: absolute; bottom: 0; width: 100%; padding: 20px 0; 
            background: rgba(0,0,0,0.9); display: none; text-align: center; 
        }

        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes pulse { from { transform: scale(0.9); opacity: 0.7; } to { transform: scale(1.1); opacity: 1; } }
        @keyframes scanMove { 0% { top: 0%; } 50% { top: 100%; } 100% { top: 0%; } }

        #status { margin-top: 50px; font-size: 0.7rem; letter-spacing: 4px; color: var(--orange); text-shadow: 0 0 5px var(--red); }
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div id="hex-bg"></div>
    <canvas id="starfield"></canvas>

    <div class="container">
        <div id="phase1">
            <div class="hud-orb" onclick="initJarvis()">
                <div class="data-bracket tl"></div><div class="data-bracket br"></div>
                <div class="ring r1"></div><div class="ring r2"></div><div class="ring r3"></div>
                <div class="core">JIGAR</div>
            </div>
            <div id="status">HAZARD PROTOCOL: STANDBY</div>
        </div>

        <div id="protocol-screen">
            <h1 style="color: var(--red); margin:0;">GHOST CHAT v7.0</h1>
            <p style="font-family: 'Share Tech Mono'; color: var(--gold);">SYSTEM ENCRYPTION: 1024-BIT</p>
            <button class="btn-activate" onclick="toScanner()">ACTIVATE PRIVATE MODULE</button>
        </div>

        <div id="scanner-screen">
            <video id="video-feed" autoplay playsinline></video>
            <div class="scan-line"></div>
            <div class="scan-ring"></div>
            <div id="pass-area">
                <input type="password" id="passInput" placeholder="AUTH KEY" style="background:transparent; border:1px solid var(--gold); color:var(--gold); padding: 10px; width: 60%;">
                <button onclick="verifyAccess()" style="background:var(--gold); color:#000; border:none; padding:10px 15px; font-weight:bold;">VERIFY</button>
            </div>
        </div>

        <div id="final-screen" class="hidden" style="text-align: center;">
            <h1 style="color:var(--gold); font-size: 3rem; text-shadow: 0 0 30px var(--orange);">MAINFRAME LIVE</h1>
            <p style="letter-spacing: 5px;">PROTOCOL SUCCESSFUL ACTIVATED</p>
        </div>
    </div>

    <script>
        // 1. STARFIELD (Warm Colors)
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas: document.getElementById('starfield'), alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        const starGeo = new THREE.BufferGeometry();
        const starCoords = [];
        for (let i = 0; i < 5000; i++) { starCoords.push((Math.random() - 0.5) * 2000, (Math.random() - 0.5) * 2000, (Math.random() - 0.5) * 2000); }
        starGeo.setAttribute('position', new THREE.Float32BufferAttribute(starCoords, 3));
        const starMat = new THREE.PointsMaterial({ color: 0xff6600, size: 0.9 });
        const stars = new THREE.Points(starGeo, starMat);
        scene.add(stars); camera.position.z = 1;
        function animateStars() { requestAnimationFrame(animateStars); stars.rotation.y += 0.001; renderer.render(scene, camera); }
        animateStars();

        // 2. AUDIO (Heartbeat)
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playHeartbeat() {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.frequency.setValueAtTime(55, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
            osc.connect(gain); gain.connect(audioCtx.destination);
            osc.start(); osc.stop(audioCtx.currentTime + 0.1);
        }

        // 3. CORE LOGIC
        const recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
        function speak(text, callback) {
            const utter = new SpeechSynthesisUtterance(text);
            utter.pitch = 0.75; utter.rate = 1; utter.onend = callback;
            window.speechSynthesis.speak(utter);
        }

        function initJarvis() {
            document.getElementById('status').innerText = "LISTENING FOR IDENTITY...";
            speak("At your service sir, welcome sir. I am Jarvis, your AI for operation and manage the chatting site and Security protocols. Please bypass with voice match.", () => {
                recognition.start();
            });
        }

        recognition.onresult = (e) => {
            if (e.results[0][0].transcript.toLowerCase().includes("jigar")) {
                speak("Identity confirmed. Unlocking thermal protocols.", () => {
                    document.getElementById('phase1').classList.add('hidden');
                    document.getElementById('protocol-screen').style.display = 'block';
                });
            }
        };

        async function toScanner() {
            document.getElementById('protocol-screen').style.display = 'none';
            document.getElementById('scanner-screen').style.display = 'block';
            const stream = await navigator.mediaDevices.getUserMedia({ video: true });
            document.getElementById('video-feed').srcObject = stream;
            
            speak("Scanning biometric data. Thermal sensors online.");
            let heartbeat = setInterval(playHeartbeat, 700);

            setTimeout(() => {
                clearInterval(heartbeat);
                speak("Scan successful. Enter authorization key.");
                document.getElementById('pass-area').style.display = "block";
            }, 3500);
        }

        function verifyAccess() {
            if (document.getElementById('passInput').value === "Jigar@2026") {
                speak("Sir, Protocol successful activated and now message online.", () => {
                    document.getElementById('scanner-screen').style.display = 'none';
                    document.getElementById('final-screen').classList.remove('hidden');
                });
            } else {
                speak("Invalid key. Emergency reset.");
                location.reload();
            }
        }
    </script>
</body>
</html>

